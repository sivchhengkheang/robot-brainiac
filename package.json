{
  "name": "robot-obstacle",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on tcp:3000 && electron .\"",
    "electron:build": "vite build && tsc -p electron/tsconfig.json && electron-builder",
    "build:linux": "vite build && tsc -p electron/tsconfig.json && electron-builder --linux AppImage",
    "build:win": "vite build && tsc -p electron/tsconfig.json && electron-builder --win nsis",
    "build:all": "vite build && tsc -p electron/tsconfig.json && electron-builder --linux AppImage --win nsis"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@tailwindcss/vite": "^4.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.robotbrainiac.app",
    "productName": "Robot Brainiac",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "icon": "public/brainiac-logo.png"
  }
}
